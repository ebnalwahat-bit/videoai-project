name: Create production builds
on:
  workflow_dispatch:

jobs:
  create-builds:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '18'

      - name: Install dependencies
        run: npm ci

      - name: Login to EAS
        env:
          EAS_TOKEN: ${{ secrets.EAS_TOKEN }}
        run: npx eas-cli@latest login --token $EAS_TOKEN

      - name: Run EAS workflow
        env:
          EAS_TOKEN: ${{ secrets.EAS_TOKEN }}
        run: npx eas-cli@latest workflow:run create-production-builds.yml --non-interactive
